Get-ChildItem -Directory -Path "modules" | ForEach-Object {
    $modName = $_.Name
    $providerPath = "$($_.FullName)/Providers/${modName}ServiceProvider.php"
    
    $phpContent = @"
<?php

namespace Modules\\$modName\\Providers;

use Illuminate\\Support\\ServiceProvider;

class ${modName}ServiceProvider extends ServiceProvider
{
    /**
     * Register any application services.
     */
    public function register(): void
    {
        //
    }

    /**
     * Bootstrap any application services.
     */
    public function boot(): void
    {
        //
    }
}
"@

    Set-Content -Path $providerPath -Value $phpContent -Force
}
